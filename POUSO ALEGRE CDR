<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Casa dos Rolamentos</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600;700&family=Syne:wght@400;600;800&display=swap');
:root{--bg:#f0f2f5;--sur:#fff;--sur2:#f7f8fa;--bor:#dde1e8;--blue:#1a3a6b;--blue2:#2456a4;--red:#c0152a;--red2:#e8192c;--text:#1a1a2e;--muted:#7a8499;--green:#1a7a3a;--green2:#22a04a;--orange:#b35e00;--purple:#7c3aed;--badge:#eaf0fb}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:'Syne',sans-serif;min-height:100vh}
/* LOGIN */
#loginScreen{display:flex;align-items:center;justify-content:center;min-height:100vh;background:linear-gradient(135deg,var(--blue) 0%,var(--red) 100%)}
.login-card{background:#fff;border-radius:16px;padding:40px 36px;width:100%;max-width:380px;box-shadow:0 20px 60px rgba(0,0,0,.3)}
.login-card img{height:48px;display:block;margin:0 auto 24px}
.login-card h1{text-align:center;font-size:1.1rem;color:var(--blue);margin-bottom:24px;font-weight:800}
/* TOPBAR */
.topbar{background:var(--blue);padding:0 20px;display:flex;align-items:center;justify-content:space-between;height:54px;position:sticky;top:0;z-index:200;box-shadow:0 2px 8px rgba(0,0,0,.2)}
.topbar img{height:36px;object-fit:contain}
.user-badge{background:rgba(255,255,255,.15);color:#fff;border:none;border-radius:6px;font-family:'IBM Plex Mono',monospace;font-size:.72rem;padding:5px 12px;cursor:pointer}
.user-badge:hover{background:rgba(255,255,255,.25)}
/* SYNC indicator */
#syncDot{width:8px;height:8px;border-radius:50%;background:#22a04a;display:inline-block;margin-right:6px;transition:background .3s}
#syncDot.syncing{background:#e07800;animation:pulse .8s infinite}
#syncDot.error{background:var(--red)}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}
/* TABS */
.tab-bar{background:var(--sur);border-bottom:2px solid var(--bor);display:flex;padding:0 20px;overflow-x:auto}
.tab-btn{background:transparent;border:none;border-bottom:3px solid transparent;color:var(--muted);font-family:'IBM Plex Mono',monospace;font-size:.72rem;font-weight:700;text-transform:uppercase;letter-spacing:.1em;padding:13px 16px 10px;cursor:pointer;white-space:nowrap;transition:color .2s,border-color .2s;margin-bottom:-2px}
.tab-btn:hover{color:var(--blue2)}.tab-btn.active{color:var(--red);border-bottom-color:var(--red)}
.tab-page{display:none;max-width:960px;margin:0 auto;padding:24px 16px 80px}.tab-page.active{display:block}
/* CARDS */
.card{background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:22px;margin-bottom:18px;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.card-title{font-size:.68rem;font-weight:700;text-transform:uppercase;letter-spacing:.14em;color:var(--blue);margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid var(--bor);font-family:'IBM Plex Mono',monospace;display:flex;align-items:center;gap:8px;flex-wrap:wrap}
/* FORMS */
label{display:block;font-size:.7rem;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:5px;font-family:'IBM Plex Mono',monospace}
input[type=text],input[type=number],input[type=date],input[type=password],input[type=email],textarea,select{width:100%;background:var(--sur2);border:1.5px solid var(--bor);border-radius:6px;color:var(--text);font-family:'IBM Plex Mono',monospace;font-size:.84rem;padding:9px 12px;outline:none;transition:border-color .2s;margin-bottom:12px}
input:focus,textarea:focus,select:focus{border-color:var(--blue2)}
textarea{min-height:120px;resize:vertical;line-height:1.7}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}
/* BUTTONS */
.btn{border:none;border-radius:6px;font-family:'IBM Plex Mono',monospace;font-weight:700;font-size:.78rem;padding:9px 16px;cursor:pointer;transition:background .2s;white-space:nowrap}
.btn-red{background:var(--red);color:#fff}.btn-red:hover{background:var(--red2)}
.btn-blue{background:var(--blue);color:#fff}.btn-blue:hover{background:var(--blue2)}
.btn-green{background:var(--green);color:#fff}.btn-green:hover{background:var(--green2)}
.btn-ghost{background:var(--sur2);color:var(--text);border:1.5px solid var(--bor)}.btn-ghost:hover{background:#e8eaf0}
.btn-primary{width:100%;background:var(--red);color:#fff;border:none;border-radius:7px;font-family:'Syne',sans-serif;font-weight:800;font-size:.95rem;padding:13px;cursor:pointer;transition:background .2s;margin-top:4px}
.btn-primary:hover{background:var(--red2)}
.actions-row{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:14px}
/* ALERTS */
.err{color:var(--red);font-size:.78rem;font-family:'IBM Plex Mono',monospace;background:#fff0f1;border:1px solid #fcc;border-radius:5px;padding:9px 13px;margin-bottom:12px}
.ok{color:var(--green);font-size:.78rem;font-family:'IBM Plex Mono',monospace;background:#f0fff4;border:1px solid #b2dfcb;border-radius:5px;padding:9px 13px;margin-bottom:12px}
.hidden{display:none!important}
/* TABLES */
.tbl{width:100%;border-collapse:collapse;font-family:'IBM Plex Mono',monospace;font-size:.79rem}
.tbl th{text-align:left;color:var(--muted);font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;padding:7px 10px;border-bottom:2px solid var(--bor);background:var(--sur2)}
.tbl td{padding:9px 10px;border-bottom:1px solid #eef0f4;vertical-align:middle}
.tbl tbody tr:hover td{background:#f5f7fb}
/* BADGES */
.badge{display:inline-block;border-radius:4px;font-size:.63rem;font-weight:700;padding:2px 8px;text-transform:uppercase;letter-spacing:.06em;font-family:'IBM Plex Mono',monospace}
.badge-blue{background:var(--badge);color:var(--blue2)}
.badge-red{background:#fff0f1;color:var(--red)}
.badge-orange{background:#fff3e0;color:var(--orange)}
.badge-green{background:#f0fff4;color:var(--green)}
/* STAT CARDS */
.stat{background:var(--sur);border:1px solid var(--bor);border-radius:10px;padding:16px 18px;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.stat .lbl{font-size:.65rem;font-family:'IBM Plex Mono',monospace;text-transform:uppercase;letter-spacing:.1em;color:var(--muted);margin-bottom:5px}
.stat .val{font-size:1.4rem;font-weight:800;font-family:'IBM Plex Mono',monospace}
/* NF ROWS */
.nf-row{background:var(--sur);border:1.5px solid var(--bor);border-radius:8px;padding:14px 16px;margin-bottom:12px}
/* AUTOCOMPLETE */
.ac-wrap{position:relative}
.ac-drop{position:absolute;top:100%;left:0;right:0;background:var(--sur);border:1.5px solid var(--blue2);border-top:none;border-radius:0 0 6px 6px;z-index:400;max-height:180px;overflow-y:auto;box-shadow:0 4px 12px rgba(0,0,0,.1)}
.ac-item{padding:8px 12px;font-family:'IBM Plex Mono',monospace;font-size:.8rem;cursor:pointer;border-bottom:1px solid var(--bor)}
.ac-item:hover{background:var(--badge);color:var(--blue)}
/* META BARS */
.meta-bar-wrap{margin-bottom:18px}
.meta-bar-label{display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:.75rem;margin-bottom:5px}
.meta-bar-bg{background:#e8eaf0;border-radius:20px;height:22px;overflow:hidden}
.meta-bar-fill{height:100%;border-radius:20px;transition:width .6s ease;display:flex;align-items:center;justify-content:flex-end;padding-right:10px;font-family:'IBM Plex Mono',monospace;font-size:.7rem;font-weight:700;color:#fff;min-width:30px}
/* MODAL */
.modal-ov{display:none;position:fixed;inset:0;background:rgba(10,20,40,.5);z-index:500;align-items:center;justify-content:center;padding:16px}
.modal-ov.open{display:flex}
.modal{background:var(--sur);border-radius:12px;padding:26px;width:100%;max-width:720px;max-height:90vh;overflow-y:auto;box-shadow:0 8px 40px rgba(0,0,0,.2)}
.modal-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:18px}
.modal-hdr h2{font-size:1rem;font-weight:800;color:var(--blue)}
.modal-close{background:none;border:none;font-size:1.4rem;color:var(--muted);cursor:pointer}
/* PRINT */
@media print{*{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}body{background:#fff!important}.topbar,.tab-bar,.tab-page,.modal-ov{display:none!important}#printArea{display:block!important;position:fixed;top:0;left:0;width:100%;background:#fff;padding:0}}
#printArea{display:none}
.pdf-page{padding:28px 32px;font-family:Arial,sans-serif}
.pdf-hdr{display:flex;align-items:center;justify-content:space-between;padding-bottom:14px;border-bottom:3px solid var(--red);margin-bottom:16px}
.pdf-cli-box{background:#f5f7fb;border:1px solid var(--bor);border-radius:6px;padding:12px 16px;margin-bottom:16px;font-size:11px}
.pdf-tbl{width:100%;border-collapse:collapse;font-size:11px}
.pdf-tbl th{background:#1a3a6b;color:#fff;padding:7px 10px;text-align:left;font-size:10px;text-transform:uppercase}
.pdf-tbl td{padding:7px 10px;border-bottom:1px solid #e8eaf0}
.pdf-tbl tr:nth-child(even) td{background:#f5f7fb}
.pdf-total td{background:#1a3a6b!important;color:#fff!important;font-weight:700!important}
.pdf-footer{text-align:center;font-size:9px;color:#aaa;margin-top:20px;border-top:1px solid #eee;padding-top:8px}
</style>
</head>
<body>

<!-- LOGIN -->
<div id="loginScreen">
  <div class="login-card">
    <img id="loginLogo" alt="Casa dos Rolamentos">
    <h1>Acesso ao Sistema</h1>
    <div><label>E-mail</label><input type="email" id="loginEmail" placeholder="seu@email.com" onkeydown="if(event.key==='Enter')fazerLogin()"></div>
    <div><label>Senha</label><input type="password" id="loginSenha" placeholder="••••••••" onkeydown="if(event.key==='Enter')fazerLogin()"></div>
    <div class="err hidden" id="loginErr"></div>
    <button class="btn-primary" onclick="fazerLogin()" id="loginBtn">ENTRAR</button>
  </div>
</div>

<!-- APP -->
<div id="app" class="hidden">
  <div class="topbar">
    <img id="topLogo" alt="Casa dos Rolamentos">
    <div style="display:flex;gap:10px;align-items:center">
      <span style="font-size:.72rem;color:rgba(255,255,255,.7);font-family:'IBM Plex Mono',monospace"><span id="syncDot"></span><span id="syncTxt">Conectado</span></span>
      <button class="user-badge" onclick="sair()">👤 <span id="userName"></span> · Sair</button>
    </div>
  </div>
  <div class="tab-bar">
    <button class="tab-btn" onclick="showTab('produtos',this)">🔩 Produtos</button>
    <button class="tab-btn active" onclick="showTab('dashboard',this)">📊 Dashboard</button>
    <button class="tab-btn" onclick="showTab('junior',this)">🏭 Junior</button>
    <button class="tab-btn" onclick="showTab('estoque',this)">📦 Estoque</button>
    <button class="tab-btn" onclick="showTab('clientes',this)">👥 Clientes</button>
    <button class="tab-btn" onclick="showTab('nf',this)">🧾 Notas Fiscais</button>
    <button class="tab-btn" onclick="showTab('metas',this)">🎯 Metas</button>
    <button class="tab-btn" onclick="showTab('historico',this)">📂 Histórico</button>
  </div>

  <!-- PRODUTOS / CATÁLOGO ARCA × SABÓ -->
  <div class="tab-page" id="tab-produtos">
    <div class="card">
      <div class="card-title" style="justify-content:space-between;flex-wrap:wrap;gap:8px">
        <span>🔩 Catálogo de Retentores — ARCA × Sabó</span>
        <span id="sabo-counter" style="font-size:.7rem;color:var(--muted);font-weight:400;font-family:'IBM Plex Mono',monospace"></span>
      </div>
      <!-- FILTROS -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:14px">
        <div>
          <label>Eixo — Ø Int (mm)</label>
          <input type="text" id="sabo-eixo" placeholder="Ex: 20.00" style="margin:0" oninput="filtrarSabo()">
        </div>
        <div>
          <label>Alojamento — Ø Ext (mm)</label>
          <input type="text" id="sabo-aloj" placeholder="Ex: 35.00" style="margin:0" oninput="filtrarSabo()">
        </div>
        <div>
          <label>Altura (mm)</label>
          <input type="text" id="sabo-alt" placeholder="Ex: 7.00" style="margin:0" oninput="filtrarSabo()">
        </div>
        <div>
          <label>Código Sabó</label>
          <input type="text" id="sabo-cod" placeholder="Ex: 01924" style="margin:0" oninput="filtrarSabo()">
        </div>
        <div>
          <label>Código ARCA</label>
          <input type="text" id="sabo-arca" placeholder="Ex: 5582" style="margin:0" oninput="filtrarSabo()">
        </div>
        <div>
          <label>Material / Tipo</label>
          <input type="text" id="sabo-mat" placeholder="Ex: NBR, ACM, FPM" style="margin:0" oninput="filtrarSabo()">
        </div>
        <div style="display:flex;align-items:flex-end;padding-bottom:0">
          <button class="btn btn-ghost" style="width:100%;margin-bottom:0" onclick="limparSabo()">🗑 Limpar</button>
        </div>
      </div>
      <!-- TABELA -->
      <div style="overflow-x:auto;border:1px solid var(--bor);border-radius:8px">
        <table class="tbl" id="sabo-tabela">
          <thead>
            <tr>
              <th style="cursor:pointer" onclick="ordenarSabo('e')">Eixo Ø Int <span id="ord-e"></span></th>
              <th style="cursor:pointer" onclick="ordenarSabo('a')">Alojamento Ø Ext <span id="ord-a"></span></th>
              <th style="cursor:pointer" onclick="ordenarSabo('h')">Altura <span id="ord-h"></span></th>
              <th>Cód. Sabó</th>
              <th>Cód. ARCA</th>
              <th>Material</th>
            </tr>
          </thead>
          <tbody id="sabo-corpo"></tbody>
        </table>
      </div>
      <div id="sabo-paginacao" style="display:flex;justify-content:space-between;align-items:center;padding:10px 4px 0;flex-wrap:wrap;gap:8px"></div>
    </div>
  </div>

  <!-- DASHBOARD -->
  <div class="tab-page active" id="tab-dashboard">
    <div class="g4" style="margin-bottom:18px" id="dash-stats"></div>
    <div class="g2">
      <div class="card"><div class="card-title">📅 Contas a Pagar — Próximas Semanas</div><canvas id="chartContas" height="200"></canvas></div>
      <div class="card"><div class="card-title">📈 Vendas vs Meta do Mês</div><canvas id="chartMeta" height="200"></canvas></div>
    </div>
    <div class="card"><div class="card-title">⚠️ Vencimentos Próximos (30 dias)</div><div id="dash-vencimentos"></div></div>
  </div>

  <!-- JUNIOR -->
  <div class="tab-page" id="tab-junior">
    <div class="card">
      <div class="card-title">🏭 Orçamento Junior <span id="j-numDisplay" style="background:var(--red);color:#fff;border-radius:4px;font-size:.72rem;padding:2px 10px">Nº —</span></div>
      <div class="g2" style="margin-bottom:4px">
        <div><label>Cliente</label><div class="ac-wrap"><input type="text" id="j-cliente" placeholder="Razão social" autocomplete="off" oninput="acShow('j-cliente','clientes')" onblur="acHide('j-cliente')" onfocus="acShow('j-cliente','clientes')"><div class="ac-drop" id="ac-j-cliente" style="display:none"></div></div></div>
        <div><label>CNPJ / CPF</label><input type="text" id="j-cnpj" placeholder="00.000.000/0000-00"></div>
      </div>
      <div><label>Endereço</label><input type="text" id="j-endereco" placeholder="Rua, número, cidade — UF"></div>
      <label>Itens (um por linha)</label>
      <textarea id="j-inputRaw" placeholder="( 2 PC ) 6911 DDU - 101.08 +(7.8 % IPI), (4,00 % ICMS), (CST:200) - NSK&#10;( 1 CJ ) 368A/362A - 108.53 +(7.8 % IPI), (4,00 % ICMS), (CST:200) - TIMKEN"></textarea>
      <div class="g2"><div><label>Margem (%)</label><input type="number" id="j-margem" placeholder="125" min="0" step=".01"></div></div>
      <div class="err hidden" id="j-err"></div>
      <button class="btn-primary" onclick="processarJunior()">▶ GERAR ORÇAMENTO</button>
    </div>
    <div class="card hidden" id="j-cardInterno">
      <div class="card-title">📊 Resumo Interno</div>
      <table class="tbl"><thead><tr><th>Qtd</th><th>Código</th><th>Marca</th><th>Custo</th><th>Venda Unit.</th><th>Total</th></tr></thead><tbody id="j-tbodyInterno"></tbody></table>
      <div id="j-totaisInterno" style="display:flex;justify-content:flex-end;gap:24px;padding:12px 10px 0;border-top:2px solid var(--bor);margin-top:4px"></div>
    </div>
    <div class="card hidden" id="j-cardCliente">
      <div class="card-title">📤 Orçamento para o Cliente</div>
      <div class="actions-row">
        <button class="btn btn-blue" onclick="gerarPDF('junior')">🖨 PDF</button>
        <button class="btn btn-green" onclick="salvarOrcamento('junior')">💾 Salvar</button>
        <button class="btn btn-ghost" onclick="copiarTextoJunior()" id="btn-cj">📋 Copiar</button>
        <button class="btn btn-ghost" onclick="limpar('junior')">🗑 Novo</button>
      </div>
      <div class="ok hidden" id="j-ok"></div>
      <table class="tbl"><thead><tr><th>Qtd</th><th>Código</th><th>Marca</th><th>Vlr Unit.</th><th>Vlr Total</th></tr></thead><tbody id="j-tbodyCliente"></tbody></table>
      <div id="j-totaisCliente" style="display:flex;justify-content:flex-end;padding:12px 10px 0;border-top:2px solid var(--bor);margin-top:4px"></div>
    </div>
  </div>

  <!-- ESTOQUE -->
  <div class="tab-page" id="tab-estoque">
    <div class="card">
      <div class="card-title">📦 Orçamento Estoque <span id="e-numDisplay" style="background:var(--red);color:#fff;border-radius:4px;font-size:.72rem;padding:2px 10px">Nº —</span></div>
      <div class="g2" style="margin-bottom:4px">
        <div><label>Cliente</label><div class="ac-wrap"><input type="text" id="e-cliente" placeholder="Razão social" autocomplete="off" oninput="acShow('e-cliente','clientes')" onblur="acHide('e-cliente')" onfocus="acShow('e-cliente','clientes')"><div class="ac-drop" id="ac-e-cliente" style="display:none"></div></div></div>
        <div><label>CNPJ / CPF</label><input type="text" id="e-cnpj" placeholder="00.000.000/0000-00"></div>
      </div>
      <div><label>Endereço</label><input type="text" id="e-endereco" placeholder="Rua, número, cidade — UF"></div>
      <div style="display:grid;grid-template-columns:70px 1fr 1fr 120px 28px;gap:10px;padding:0 12px 4px;margin-bottom:4px">
        <label style="margin:0">Qtd</label><label style="margin:0">Código</label><label style="margin:0">Marca</label><label style="margin:0">Valor Unit.</label><span></span>
      </div>
      <div id="e-itens"></div>
      <button class="btn btn-ghost" style="width:100%;border:1.5px dashed var(--bor);margin-bottom:12px" onclick="addItemEstoque()">+ Adicionar Item</button>
      <div class="err hidden" id="e-err"></div>
      <button class="btn-primary" onclick="processarEstoque()">▶ GERAR ORÇAMENTO</button>
    </div>
    <div class="card hidden" id="e-cardCliente">
      <div class="card-title">📤 Orçamento para o Cliente</div>
      <div class="actions-row">
        <button class="btn btn-blue" onclick="gerarPDF('estoque')">🖨 PDF</button>
        <button class="btn btn-green" onclick="salvarOrcamento('estoque')">💾 Salvar</button>
        <button class="btn btn-ghost" onclick="copiarTextoEstoque()" id="btn-ce">📋 Copiar</button>
        <button class="btn btn-ghost" onclick="limpar('estoque')">🗑 Novo</button>
      </div>
      <div class="ok hidden" id="e-ok"></div>
      <table class="tbl"><thead><tr><th>Qtd</th><th>Código</th><th>Marca</th><th>Vlr Unit.</th><th>Vlr Total</th></tr></thead><tbody id="e-tbodyCliente"></tbody></table>
      <div id="e-totaisCliente" style="display:flex;justify-content:flex-end;padding:12px 10px 0;border-top:2px solid var(--bor);margin-top:4px"></div>
    </div>
  </div>

  <!-- CLIENTES -->
  <div class="tab-page" id="tab-clientes">
    <div class="card">
      <div class="card-title">👥 Cadastrar Cliente</div>
      <div class="g3" style="margin-bottom:4px">
        <div><label>Nome / Razão Social</label><input type="text" id="cli-nome" placeholder="Nome do cliente"></div>
        <div><label>CNPJ / CPF</label><input type="text" id="cli-cnpj" placeholder="00.000.000/0000-00"></div>
        <div><label>Telefone</label><input type="text" id="cli-tel" placeholder="(00) 00000-0000"></div>
      </div>
      <div><label>Endereço</label><input type="text" id="cli-end" placeholder="Rua, número, cidade — UF"></div>
      <div class="err hidden" id="cli-err"></div>
      <button class="btn btn-red" onclick="salvarCliente()">+ Cadastrar</button>
    </div>
    <div class="card">
      <div class="card-title" style="justify-content:space-between">
        <span>📋 Clientes</span>
        <input type="text" id="cli-busca" placeholder="Buscar..." style="margin:0;width:180px;padding:5px 10px;font-size:.75rem" oninput="renderClientes()">
      </div>
      <div id="cli-lista"></div>
    </div>
  </div>

  <!-- NOTAS FISCAIS -->
  <div class="tab-page" id="tab-nf">
    <div class="g4" style="margin-bottom:18px">
      <div class="stat"><div class="lbl">NFs em Aberto</div><div class="val" id="nf-totalAberto" style="color:var(--red)">R$ 0,00</div></div>
      <div class="stat"><div class="lbl">Fretes em Aberto</div><div class="val" id="nf-totalFrete" style="color:var(--orange)">R$ 0,00</div></div>
