// JUNIOR
function extrairItem(linha) {
  linha=linha.trim(); if(!linha) return null;
  const qm=linha.match(/\(\s*(\d+)\s*([A-ZÇÃÕa-zçãõ]{1,5})\s*\)/i);
  const qtd=qm?parseInt(qm[1]):1, un=qm?qm[2].toUpperCase():'PC';
  const cm=linha.match(/\)\s+([\w][\w\s\/\-\.]*?)\s*[-–]\s*([\d.,]+)(?:\s|$|\+|\()/i);
  if(!cm) return {erro:linha};
  const codigo=cm[1].trim(), valorBase=parseFloat(cm[2].replace(',','.'));
  if(isNaN(valorBase)) return {erro:linha};
  const im=linha.match(/\(?\s*([\d.,]+)\s*%?\s*IPI\s*\)?/i);
  const mm=linha.match(/[-–]\s*([A-Z0-9][A-Z0-9\s\-\.]*?)\s*$/i);
  return {qtd,unidade:un,codigo,valorBase,ipi:im?parseFloat(im[1].replace(',','.')):null,marca:mm?mm[1].trim():''};
}

function processarJunior() {
