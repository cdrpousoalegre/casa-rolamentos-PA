async function renderNFs(){
  const db=await getNFs();
  const qForn=(document.getElementById('nf-busca-forn')?.value||'').toLowerCase();
  const qNum=(document.getElementById('nf-busca-num')?.value||'').toLowerCase();
  const qSt=document.getElementById('nf-busca-status')?.value||'';
  let list=[...db];
  if(qForn) list=list.filter(n=>n.fornecedor.toLowerCase().includes(qForn));
  if(qNum) list=list.filter(n=>(n.numero||'').toLowerCase().includes(qNum)||(n.cte?.numero||'').toLowerCase().includes(qNum));
  if(qSt) list=list.filter(n=>{if(qSt==='frete-aberto')return n.cte&&!n.cte.pago;if(qSt==='frete-pago')return n.cte&&n.cte.pago;return(n.parcelas||[]).some(p=>(p.paga?'paga':statusParcela(p.venc))===qSt);});
  const lista=document.getElementById('nf-lista');
  if(!list.length){lista.innerHTML=empty('Nenhuma nota encontrada.');return;}
  const stLbl={aberto:'Em Aberto',vencendo:'Vencendo',vencida:'Vencida',paga:'Paga'};
  const stCor={aberto:'var(--blue2)',vencendo:'var(--orange)',vencida:'var(--red)',paga:'var(--green)'};
  lista.innerHTML=list.map(nf=>{
    const parc=nf.parcelas||[];
    const totAb=parc.filter(p=>!p.paga).reduce((s,p)=>s+p.valor,0);
    const todasPagas=parc.length>0&&parc.every(p=>p.paga);
