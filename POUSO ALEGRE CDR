function _saboNorm(s){ return (s||'').replace(/,/g,'.').toLowerCase(); }
function _matClass(t){
  if(!t) return 'mat-other';
  const u=t.toUpperCase();
  if(u.includes('HNBR')) return 'mat-HNBR';
  if(u.includes('NBR'))  return 'mat-NBR';
  if(u.includes('ACM'))  return 'mat-ACM';
  if(u.includes('FPM'))  return 'mat-FPM';
  if(u.includes('MVQ'))  return 'mat-MVQ';
  if(u.includes('CR'))   return 'mat-CR';
  if(u.includes('PU'))   return 'mat-PU';
  return 'mat-other';
}
const _matColors={
  'mat-NBR':'background:#d5f5e3;color:#1e8449',
  'mat-ACM':'background:#e8daef;color:#6c3483',
  'mat-FPM':'background:#fde8d8;color:#a04000',
  'mat-MVQ':'background:#d6eaf8;color:#1a5276',
  'mat-HNBR':'background:#d1f2eb;color:#0e6655',
  'mat-CR':'background:#fef9e7;color:#9a7d0a',
  'mat-PU':'background:#f9ebea;color:#922b21',
  'mat-other':'background:#f2f3f4;color:#566573',
};
let _saboFiltrado=[..._saboDb],_saboPage=1,_saboOrd={col:'e',dir:1};
const _saboPerPage=60;

function filtrarSabo(){
  const fE=_saboNorm(document.getElementById('sabo-eixo')?.value||'');
  const fA=_saboNorm(document.getElementById('sabo-aloj')?.value||'');
  const fH=_saboNorm(document.getElementById('sabo-alt')?.value||'');
  const fC=(document.getElementById('sabo-cod')?.value||'').toLowerCase();
  const fAr=(document.getElementById('sabo-arca')?.value||'').toLowerCase();
  const fT=(document.getElementById('sabo-mat')?.value||'').toLowerCase();
  _saboFiltrado=_saboDb.filter(i=>
    (!fE||_saboNorm(i.e).includes(fE))&&
    (!fA||_saboNorm(i.a).includes(fA))&&
    (!fH||_saboNorm(i.h).includes(fH))&&
    (!fC||(i.c||'').toLowerCase().includes(fC))&&
    (!fAr||(i.ar||'').toLowerCase().includes(fAr))&&
    (!fT||(i.t||'').toLowerCase().includes(fT))
  );
  _saboPage=1; _saboOrdenarAplicar(); renderSabo();
}

function ordenarSabo(col){
  if(_saboOrd.col===col)_saboOrd.dir*=-1; else{_saboOrd.col=col;_saboOrd.dir=1;}
  _saboOrdenarAplicar(); renderSabo();
}

function _saboOrdenarAplicar(){
  const col=_saboOrd.col;
  _saboFiltrado.sort((a,b)=>(parseFloat(_saboNorm(a[col]))||0)-(parseFloat(_saboNorm(b[col]))||0)*_saboOrd.dir);
  _saboFiltrado.sort((a,b)=>((parseFloat(_saboNorm(a[col]))||0)-(parseFloat(_saboNorm(b[col]))||0))*_saboOrd.dir);
}

function renderSabo(){
  const corpo=document.getElementById('sabo-corpo');
  if(!corpo) return;
  const total=_saboFiltrado.length;
  const pages=Math.max(1,Math.ceil(total/_saboPerPage));
  if(_saboPage>pages)_saboPage=pages;
  const start=(_saboPage-1)*_saboPerPage;
  const slice=_saboFiltrado.slice(start,start+_saboPerPage);

  ['e','a','h'].forEach(c=>{
    const el=document.getElementById('ord-'+c);
    if(el) el.textContent=_saboOrd.col===c?(_saboOrd.dir===1?' ▲':' ▼'):'';
  });

  const counter=document.getElementById('sabo-counter');
  if(counter) counter.textContent=total===_saboDb.length
    ?total+' itens no catálogo'
    :total+' resultado'+(total!==1?'s':'')+' de '+_saboDb.length;

  if(!slice.length){
    corpo.innerHTML='<tr><td colspan="6" style="text-align:center;color:var(--muted);padding:28px;font-family:IBM Plex Mono,monospace;font-size:.82rem">Nenhum retentor encontrado.</td></tr>';
    document.getElementById('sabo-paginacao').innerHTML='';
    return;
  }

  corpo.innerHTML=slice.map(i=>{
    const mc=_matClass(i.t);
    const ms=_matColors[mc]||_matColors['mat-other'];
    const badC=(i.c&&i.c.trim().length>2&&!['N','H','/'].includes(i.c.trim()))
      ?'<span class="badge badge-red" style="font-size:.7rem">'+i.c+'</span>'
      :'<span style="color:var(--muted)">—</span>';
    const badA=(i.ar&&i.ar.trim())
      ?'<span class="badge badge-blue" style="font-size:.7rem">'+i.ar+'</span>'
      :'<span style="color:var(--muted)">—</span>';
    return '<tr>'+
      '<td style="font-family:IBM Plex Mono,monospace;font-weight:700;color:var(--blue)">'+i.e+'</td>'+
      '<td style="font-family:IBM Plex Mono,monospace">'+i.a+'</td>'+
      '<td style="font-family:IBM Plex Mono,monospace">'+i.h+'</td>'+
      '<td>'+badC+'</td>'+
      '<td>'+badA+'</td>'+
      '<td><span style="display:inline-block;padding:2px 8px;border-radius:4px;font-size:.72rem;font-weight:700;'+ms+'">'+( i.t||'—')+'</span></td>'+
      '</tr>';
  }).join('');

  const pag=document.getElementById('sabo-paginacao');
  if(!pag) return;
  pag.innerHTML=
    '<span style="font-family:IBM Plex Mono,monospace;font-size:.72rem;color:var(--muted)">Página '+_saboPage+' de '+pages+' · itens '+(start+1)+'–'+Math.min(start+_saboPerPage,total)+'</span>'+
    '<div style="display:flex;gap:8px">'+
    '<button class="btn btn-ghost" style="padding:5px 14px;font-size:.75rem" onclick="_saboPage--;renderSabo()"'+(_saboPage<=1?' disabled':'')+'>← Anterior</button>'+
    '<button class="btn btn-ghost" style="padding:5px 14px;font-size:.75rem" onclick="_saboPage++;renderSabo()"'+(_saboPage>=pages?' disabled':'')+'">Próxima →</button>'+
    '</div>';
}

function limparSabo(){
  ['sabo-eixo','sabo-aloj','sabo-alt','sabo-cod','sabo-arca','sabo-mat'].forEach(id=>{
    const el=document.getElementById(id);if(el)el.value='';
  });
  _saboFiltrado=[..._saboDb];_saboPage=1;_saboOrdenarAplicar();renderSabo();
}


