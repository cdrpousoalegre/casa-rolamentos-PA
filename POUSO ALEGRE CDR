const METAS=[80000,100000,120000,150000];
async function lancarVenda(){
  const data=document.getElementById('meta-data').value;
  const valor=parseFloat(document.getElementById('meta-valor').value);
  const err=document.getElementById('meta-err'); err.classList.add('hidden');
  if(!data){err.textContent='⚠ Selecione a data.';err.classList.remove('hidden');return;}
  if(isNaN(valor)||valor<=0){err.textContent='⚠ Informe o valor.';err.classList.remove('hidden');return;}
  // Upsert: se já existe para essa data, atualiza
  const existing=await sbFetch('vendas_diarias?data=eq.'+data);
  if(existing.length){
    await sb.patch('vendas_diarias',existing[0].id,{valor:existing[0].valor+valor});
  } else {
    await sb.post('vendas_diarias',{data,valor});
  }
  document.getElementById('meta-valor').value='';
  renderMetas();
}
async function excluirVenda(id){ if(!confirm('Excluir lançamento?'))return; await sb.del('vendas_diarias',id); renderMetas(); }

function diasUteisRestantes(){
  const hj=new Date(),ano=hj.getFullYear(),mes=hj.getMonth();
  const ultDia=new Date(ano,mes+1,0).getDate(); let count=0;
  for(let d=hj.getDate();d<=ultDia;d++){const dia=new Date(ano,mes,d).getDay();if(dia!==0&&dia!==6)count++;}
  return count;
}
async function populateMesSel(){
  const sel=document.getElementById('meta-mes-sel'); if(!sel) return;
  const vendas=await sbFetch('vendas_diarias?select=data&order=data.desc');
  const meses=[...new Set(vendas.map(v=>v.data.slice(0,7)))];
  const atual=mesAtual();
  const todos=[...new Set([atual,...meses])].sort().reverse();
  const cur=sel.value||atual;
  sel.innerHTML=todos.map(m=>`<option value="${m}" ${m===cur?'selected':''}>${m}</option>`).join('');
}
async function renderMetas(){
  await populateMesSel();
  const mes=document.getElementById('meta-mes-sel')?.value||mesAtual();
  const vendas=await sbFetch(`vendas_diarias?data=gte.${mes}-01&data=lte.${mes}-31&order=data.desc`);
  const total=vendas.reduce((s,v)=>s+v.valor,0);
  const duR=diasUteisRestantes();
  const painel=document.getElementById('meta-painel'); if(!painel) return;
  const cores=['#2456a4','#22a04a','#b35e00','#c0152a'];
  const labels=['Meta 1','Meta 2','Meta 3','Meta 4'];
  const barras=METAS.map((m,i)=>{
    const pct=Math.min((total/m)*100,100).toFixed(1),falta=Math.max(m-total,0),med=duR>0?(falta/duR):0;
    return `<div class="meta-bar-wrap"><div class="meta-bar-label"><span style="font-weight:700;color:${cores[i]}">${labels[i]} — R$ ${fmt(m)}</span><span style="color:${total>=m?'var(--green)':'var(--muted)'}">${total>=m?'✅ ATINGIDA':pct+'%'}</span></div><div class="meta-bar-bg"><div class="meta-bar-fill" style="width:${pct}%;background:${cores[i]}">${pct}%</div></div><div style="display:flex;justify-content:space-between;font-family:'IBM Plex Mono',monospace;font-size:.68rem;color:var(--muted);margin-top:3px"><span>Falta: <strong style="color:${cores[i]}">R$ ${fmt(falta)}</strong></span>${total<m?`<span>Média/dia útil: <strong>R$ ${fmt(med)}</strong></span>`:''}</div></div>`;
  }).join('');
  painel.innerHTML=`<div class="card-title">🎯 Metas — ${mes}</div><div style="display:flex;gap:24px;flex-wrap:wrap;margin-bottom:18px"><div><div style="font-size:.66rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase">Total Vendido</div><div style="font-size:1.5rem;font-weight:800;color:var(--blue);font-family:'IBM Plex Mono',monospace">R$ ${fmt(total)}</div></div><div><div style="font-size:.66rem;color:var(--muted);font-family:'IBM Plex Mono',monospace;text-transform:uppercase">Dias Úteis Restantes</div><div style="font-size:1.5rem;font-weight:800;color:var(--orange);font-family:'IBM Plex Mono',monospace">${duR}</div></div></div>${barras}`;
  const vlista=document.getElementById('meta-vendas-lista'); if(!vlista) return;
  vlista.innerHTML=vendas.length?vendas.map(v=>`<div style="display:flex;justify-content:space-between;align-items:center;padding:9px 12px;border-bottom:1px solid var(--bor);font-family:'IBM Plex Mono',monospace"><span style="font-size:.82rem">${fmtData(v.data)}</span><div style="display:flex;align-items:center;gap:12px"><span style="font-weight:700;font-size:.9rem;color:var(--green)">R$ ${fmt(v.valor)}</span><button onclick="excluirVenda(${v.id})" style="background:#fff0f1;color:var(--red);border:1px solid #fcc;border-radius:4px;font-size:.72rem;padding:3px 7px;cursor:pointer">✕</button></div></div>`).join(''):empty('Nenhuma venda lançada.');
  renderChartHistMeta(mes);
}

