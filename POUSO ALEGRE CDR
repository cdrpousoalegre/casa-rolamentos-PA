async function lancarNF(){
  const forn=document.getElementById('nf-forn').value.trim();
  const num=document.getElementById('nf-num').value.trim();
  const chave=document.getElementById('nf-chave').value.trim();
  const valor=parseFloat(document.getElementById('nf-valor').value);
  const transp=document.getElementById('nf-transp').value.trim();
  const cteNum=document.getElementById('nf-cte-num').value.trim();
  const cteChave=document.getElementById('nf-cte-chave').value.trim();
  const cteValor=parseFloat(document.getElementById('nf-cte-valor').value);
  const cteVenc=document.getElementById('nf-cte-venc').value;
  const err=document.getElementById('nf-err'); err.classList.add('hidden');
  if(!forn){err.textContent='⚠ Informe o fornecedor.';err.classList.remove('hidden');return;}
  if(!num){err.textContent='⚠ Informe o número.';err.classList.remove('hidden');return;}
  if(isNaN(valor)||valor<=0){err.textContent='⚠ Informe o valor.';err.classList.remove('hidden');return;}
  const parcelas=coletarParcelas();
  if(!parcelas.length){err.textContent='⚠ Adicione ao menos um vencimento.';err.classList.remove('hidden');return;}
  const cte=(transp||cteNum||(cteValor>0))?{transportadora:transp,numero:cteNum,chave:cteChave,valor:isNaN(cteValor)?0:cteValor,venc:cteVenc,pago:false}:null;
  await sb.post('notas_fiscais',{fornecedor:forn,numero:num,chave,valor,parcelas,cte,lancamento:hoje()});
  ['nf-forn','nf-num','nf-chave','nf-valor','nf-transp','nf-cte-num','nf-cte-chave','nf-cte-valor','nf-cte-venc'].forEach(i=>{const el=document.getElementById(i);if(el)el.value='';});
  document.getElementById('nf-parcelas-lista').innerHTML=''; _pc=0;
  document.getElementById('nf-nparcelas').value='1';
  document.getElementById('nf-pvenc').value='';
  addParcela();
