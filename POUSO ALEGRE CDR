function renderChartContas(vencs){
  destroyChart('contas');
  const vals=[0,0,0,0];
  vencs.forEach(v=>{const hj=new Date();hj.setHours(0,0,0,0);const d=new Date(v.data+'T00:00:00'),diff=Math.floor((d-hj)/86400000);if(diff<7)vals[0]+=v.valor;else if(diff<14)vals[1]+=v.valor;else if(diff<21)vals[2]+=v.valor;else vals[3]+=v.valor;});
  const ctx=document.getElementById('chartContas')?.getContext('2d'); if(!ctx) return;
  _charts['contas']=new Chart(ctx,{type:'bar',data:{labels:['Sem 1','Sem 2','Sem 3','Sem 4'],datasets:[{label:'A Pagar (R$)',data:vals,backgroundColor:['#c0152a','#b35e00','#2456a4','#7c3aed'],borderRadius:6}]},options:{responsive:true,plugins:{legend:{display:false}},scales:{y:{ticks:{callback:v=>'R$'+fmt(v)}}}}});
}
